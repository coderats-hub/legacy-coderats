  "paths": {
    "/auth/github/callback": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Realizar login ou registro via GitHub",
        "description": "Recebe o código temporário 'code' fornecido pelo GitHub OAuth.\nO backend troca esse código por um token de acesso do GitHub,\nautentica ou cria o usuário na plataforma Code Rats,\ne retorna o perfil do usuário e um token JWT da sessão.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/github_callback_body"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Autenticação bem-sucedida. Retorna o objeto do usuário e o token JWT.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/inline_response_200"
                },
                "example": {
                  "user": {
                    "id": "a1b2c3d4-e5f6-7890-1234-567890abcdef",
                    "name": "Ana Coder",
                    "email": "ana.coder@email.com",
                    "image": "https://avatars.githubusercontent.com/u/12345",
                    "github_user": "anacoder"
                  },
                  "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJhMWIyYzNkNC1lNWY2LTc4OTAtMTIzNC01Njc4OTBhYmNkZWYifQ.token"
                }
              }
            }
          },
          "400": {
            "description": "Código 'code' inválido ou expirado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "statusCode": 400,
                  "message": "Código OAuth inválido."
                }
              }
            }
          }
        }
      }
    },
