    "/groups/join": {
      "post": {
        "tags": [
          "Grupos"
        ],
        "summary": "Entrar em um grupo usando código",
        "description": "Adiciona o usuário ao grupo correspondente ao `code`.\nPor padrão, o usuário é identificado pelo JWT em `Authorization: Bearer <token>`.\nOpcionalmente, `userId` pode ser enviado no corpo para fluxos administrativos (requer permissão).\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GroupJoinRequest"
              },
              "example": {
                "code": "123",
                "userId": "a1b2c3d4-e5f6-7890-1234-567890abcdef"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Entrada realizada com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GroupJoinResponse"
                },
                "example": {
                  "group": {
                    "id": "group-uuid-abc",
                    "name": "Desafio 30 Dias de Testes",
                    "image": "https://coderats.com/image.jpg",
                    "status": true
                  },
                  "membership": {
                    "role": "member",
                    "joined_at": "2025-11-05T22:15:00Z"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
