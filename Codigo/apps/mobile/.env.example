# CodeRats Flutter configuration
# Copy this file to .env for local Flutter runs.

# Local backend:
BASE_API_URL=http://localhost:8080

# External examples:
# BASE_API_URL=https://ca-coderats-dev-backend.redocean-3abdf16b.eastus.azurecontainerapps.io
# BASE_API_URL=https://<staging-backend-host>
# BASE_API_URL=https://<prod-backend-host>

USE_MOCK_API=false
DEV_AUTH_BYPASS=false
DEFAULT_GROUP_ID=

# Mobile ads / web ads
ADMOB_BANNER_ANDROID=
ADS_ENV=dev
ADSENSE_CLIENT=
ADSENSE_SLOT=
ADSENSE_CLIENT_TEST=
ADSENSE_SLOT_TEST=
GIT_BRANCH=
BRANCH=
