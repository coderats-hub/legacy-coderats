# CodeRats runtime configuration
# Copy this file to .env in this directory when running docker compose locally.

# --- Environment ---
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
APP_PORT=8080

# --- Backend CORS ---
# Local Flutter Web production container: http://localhost:8081
# Local Flutter Web dev server: http://localhost:8082
# Add the dev/staging/prod frontend URLs for each deployed environment.
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8082,http://localhost:8080

# --- Database used by docker compose local ---
POSTGRES_DB=coderats_db
POSTGRES_USER=coderats_user
POSTGRES_PASSWORD=change-me
DB_PORT=5432
DB_URL=jdbc:postgresql://db:5432/coderats_db
DB_USER=coderats_user
DB_PASS=change-me

# Azure PostgreSQL examples:
# dev/staging/prod should set DB_URL through the deployment environment.
# DB_URL=jdbc:postgresql://<server>.postgres.database.azure.com:5432/<database>?sslmode=require
# DB_USER=<user>
# DB_PASS=<secret>

# --- PgAdmin local only ---
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=change-me
PGADMIN_PORT=5050

# --- JWT ---
SECURITY_JWT_SECRET=replace-with-at-least-64-random-characters-for-hs512-signing
SECURITY_JWT_EXPIRATION_MS=86400000

# --- GitHub OAuth local ---
GITHUB_OAUTH_CLIENT_ID_LOCAL=
GITHUB_OAUTH_CLIENT_SECRET_LOCAL=
GITHUB_OAUTH_REDIRECT_URI_LOCAL=http://localhost:8080/auth/github/callback

# --- GitHub OAuth dev ---
GITHUB_OAUTH_CLIENT_ID_DEV=
GITHUB_OAUTH_CLIENT_SECRET_DEV=
GITHUB_OAUTH_REDIRECT_URI_DEV=https://<dev-backend-host>/auth/github/callback

# --- GitHub OAuth staging ---
GITHUB_OAUTH_CLIENT_ID_STAGING=
GITHUB_OAUTH_CLIENT_SECRET_STAGING=
GITHUB_OAUTH_REDIRECT_URI_STAGING=https://<staging-backend-host>/auth/github/callback

# --- GitHub OAuth prod ---
GITHUB_OAUTH_CLIENT_ID_PROD=
GITHUB_OAUTH_CLIENT_SECRET_PROD=
GITHUB_OAUTH_REDIRECT_URI_PROD=https://<prod-backend-host>/auth/github/callback

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_ENDPOINT=/chat/completions
OPENAI_MODEL=gpt-4.1-mini
OPENAI_SYSTEM_PROMPT=

# --- Current S3-compatible image storage ---
# Keep these explicit per environment until the Azure Blob implementation replaces S3.
AWS_REGION=us-east-1
AWS_S3_BUCKET=coderats-local-files
AWS_S3_BASE_PATH=public/images/
AWS_S3_PUBLIC_BASE_URL=http://localhost:4566/coderats-local-files

# --- Flutter Web build args used by docker compose mobile build ---
BASE_API_URL=http://localhost:8080
USE_MOCK_API=false
DEV_AUTH_BYPASS=false
